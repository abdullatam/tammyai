# Tammy AI Environment Configuration
# Copy this file to .env and fill in your actual keys.

# ── Server Configuration ──
GRADIO_SERVER_PORT=7861
LOG_LEVEL=INFO

# ── AI Providers ──
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=...
TAMMY_CHAT_MODEL=gpt-4o-mini
TAMMY_EMB_MODEL=text-embedding-3-small
TAMMY_ANTHROPIC_MODEL=claude-sonnet-4-20250514
TAMMY_GEMINI_MODEL=gemini-2.5-flash

# ── Vector DB (Pinecone) ──
PINECONE_API_KEY=pc-sk-...
TAMMY_INDEX_NAME=tammy-books
TAMMY_MEMORY_INDEX=tammy-memories
TAMMY_NAMESPACE=tammy-v1

# ── Database (MongoDB) ──
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net
MONGO_DB_NAME=tammy

# ── Cache (Redis) ──
REDIS_HOST=
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=

# ── Voice Providers ──
SPEECHMATICS_API_KEY=...
ELEVENLABS_API_KEY=...
AZURE_SPEECH_KEY=...
AZURE_SPEECH_REGION=eastus

# ── Security & Admin ──
ADMIN_PASSWORD=change_this_to_a_strong_password
DEFAULT_USER_ID=123
